[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://../rust/gd_emu/target/debug/libgd_emu.so"
linux.release.x86_64 =   "res://../rust/gd_emu/target/release/libgd_emu.so"
windows.debug.x86_64 =   "res://../rust/gd_emu/target/debug/gd_emu.dll"
windows.release.x86_64 = "res://../rust/gd_emu/target/release/gd_emu.dll"
macos.debug =            "res://../rust/gd_emu/target/debug/libgd_emu.dylib"
macos.release =          "res://../rust/gd_emu/target/release/libgd_emu.dylib"
macos.debug.arm64 =      "res://../rust/gd_emu/target/debug/libgd_emu.dylib"
macos.release.arm64 =    "res://../rust/gd_emu/target/release/libgd_emu.dylib"
